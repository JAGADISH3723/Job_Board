# ---- Frontend (Vite) ----
# Base URL of the deployed backend. Leave EMPTY for local dev (Vite proxies
# /api to http://localhost:5000). On Vercel, set this to your Render backend URL.
VITE_API_BASE=

# ---- Backend (Express on Render / local) ----
# MongoDB connection string. Local default is used if unset.
# For Render/production use your MongoDB Atlas SRV string.
MONGODB_URI=mongodb://127.0.0.1:27017/mern-job-board

# Secret used to sign JWT auth tokens. Change this in production.
JWT_SECRET=dev-secret-change-me

# OpenAI API key for the AI job-description generator (optional).
OPENAI_API_KEY=

# Port the backend listens on (Render sets this automatically).
PORT=5000
